[Rewrite]
# 知音漫画去广告
^https:\/\/(api-access\.pangolin-sdk-toutiao\.com\/api\/ad\/union\/sdk\/get_ads|open\.e\.kuaishou\.com\/rest\/e\/v3\/open\/univ$|mi\.gdt\.qq\.com\/gdt_mview\.fcg\?) url reject-200

# Super Widget去广告
^http[s]?:\/\/(/toblog\.ctobsnssdk\.com|open\.e\.kuaishou\.com|mobads\.baidu\.com|api-access\.pangolin-sdk-toutiao1\.com|adservice\.sigmob\.cn|(\.?)+\.gdt\.qq\.com)(\.?)+ url reject-200

# 音频剪辑、扫描王全能宝去广告
^https:\/\/ad\.camoryapps\.com\/(\.?)+ url reject-200

# 加画框去广告
^https:\/\/prod\.jiahk\.cn\/api\/v2\/forty\/findAdvertisement url reject-200

