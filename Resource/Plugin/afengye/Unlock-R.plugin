[Script]
# ========== 元气桌面壁纸 ==========
http-response ^https:\/\/mobile-ios-wallpaper-api\.zhhainiao\.com\/v1\/user\/info script-path=https://raw.githubusercontent.com/afengye/QX/main/yqzm.js, requires-body=true, timeout=60, tag=元气桌面解锁会员, argument=enabled={yqzm_enable}

# ========== 起名有福-宝宝取名字软件 ==========
http-response ^https:\/\/www\.qimingyoufu\.cn\/v01\/user-info script-path=https://raw.githubusercontent.com/afengye/QX/main/qiming.js, requires-body=true, timeout=60, tag=起名有福解锁会员, argument=enabled={qiming_enable}

# ========== 得见小说 ==========
